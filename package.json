{
  "name": "@wireio/wire-tools-project-root",
  "private": true,
  "scripts": {
    "compile": "tsc -b tsconfig.json",
    "compile:watch": "tsc -b tsconfig.json -w  --preserveWatchOutput",
    "build": "tsc -b tsconfig.json",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "lint": "eslint .",
    "test": "pnpm run build && NODE_OPTIONS=--experimental-vm-modules jest",
    "test:ci": "pnpm run build && NODE_OPTIONS=--experimental-vm-modules jest --reporters=default --reporters=jest-junit",
    "clean": "./scripts/clean.sh && pnpm -r run clean"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "25.5.0",
    "@types/proper-lockfile": "^4.1.4",
    "@wireio/opp-typescript-models": "^1.0.26",
    "@wireio/sdk-core": "^1.0.22",
    "@wireio/shared": "^1.0.22",
    "@wireio/shared-node": "^1.0.22",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "get-port": "^7.2.0",
    "jest": "^30.3.0",
    "jest-junit": "^16.0.0",
    "prettier": "^3.8.1",
    "proper-lockfile": "^4.1.2",
    "shelljs": "^0.10.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.64.0",
    "zx": "^8.8.5"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22"
  },
  "resolutions": {
    "@types/proper-lockfile": "4.1.4",
    "uuid": "11",
    "get-port": "7.2.0",
    "proper-lockfile": "4.1.2"
  }
}
