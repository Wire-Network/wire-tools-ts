{
  "extends": "../../etc/tsconfig/tsconfig.base.jest.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "lib/out",
    "strictNullChecks": true,
    "paths": {
      "@wireio/debugging-shared": ["../debugging-shared/src"],
      "@wireio/debugging-shared/*": ["../debugging-shared/src/*"],
      "@wireio/test-cluster-tool": ["../test-cluster-tool/src"],
      "@wireio/test-cluster-tool/*": ["../test-cluster-tool/src/*"],
      "@wireio/test-opp-stress": ["../opp-stress/src"],
      "@wireio/test-opp-stress/*": ["../opp-stress/src/*"]
    }
  },
  "include": ["src"],
  "references": [
    { "path": "../debugging-shared/tsconfig.json" },
    { "path": "../test-cluster-tool/tsconfig.json" },
    { "path": "../opp-stress/tsconfig.json" }
  ]
}
