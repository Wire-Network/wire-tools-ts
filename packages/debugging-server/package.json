{
  "name": "@wireio/debugging-server",
  "version": "0.1.16",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "type": "commonjs",
  "types": "lib/cjs/index.d.ts",
  "main": "lib/cjs/index.js",
  "bin": {
    "wire-debugging-server": "bin/wire-debugging-server",
    "wds": "bin/wire-debugging-server"
  },
  "files": [
    "dist",
    "lib",
    "bin",
    "src",
    "README.md"
  ],
  "scripts": {
    "compile": "tsc -b tsconfig.json",
    "compile:watch": "tsc -b tsconfig.json -w",
    "bundle": "node esbuild.config.js",
    "bundle:watch": "node esbuild.config.js --watch",
    "build": "pnpm run compile && pnpm run bundle",
    "prepublishOnly": "pnpm run build",
    "prepare": "pnpm run build",
    "dev": "node esbuild.config.js --dev",
    "dist": "pnpm build && pnpm bundle",
    "test": "jest",
    "clean": "rm -rf lib dist"
  },
  "dependencies": {
    "@3fv/prelude-ts": "^0.8.41",
    "@protobuf-ts/runtime": "^2.11.1",
    "@wireio/cluster-tool-shared": "workspace:*",
    "@wireio/debugging-shared": "workspace:*",
    "@wireio/opp-typescript-models": "^1.0.26",
    "@wireio/sdk-core": "^1.0.21",
    "@wireio/shared": "^1.0.21",
    "bluebird": "^3.7.2",
    "express": "^5.2.1",
    "get-port": "^7.2.0",
    "lodash": "^4.17.21",
    "source-map-support": "^0.5.21",
    "ts-pattern": "^5.9.0",
    "ws": "^8.18.0",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@types/bluebird": "^3.5.42",
    "@types/express": "^5.0.0",
    "@types/lodash": "^4.17.24",
    "@types/node": "25.5.0",
    "@types/ws": "^8.5.13",
    "@types/yargs": "^17.0.35",
    "concurrently": "^9.2.1",
    "esbuild": "^0.27.3",
    "ts-jest": "^29.4.6",
    "typescript": "^6.0.2"
  }
}
