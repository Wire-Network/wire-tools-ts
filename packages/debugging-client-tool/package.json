{
  "name": "@wireio/debugging-client-tool",
  "version": "0.1.2",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "type": "commonjs",
  "types": "lib/cjs/index.d.ts",
  "main": "dist/bundle/wire-debugging-client-tool.cjs",
  "bin": {
    "wire-debugging-client-tool": "dist/bundle/wire-debugging-client-tool.cjs"
  },
  "scripts": {
    "compile": "tsc -b tsconfig.json",
    "compile:watch": "tsc -b tsconfig.json -w",
    "bundle": "node esbuild.config.js",
    "dist": "pnpm build && pnpm bundle",
    "test": "jest",
    "clean": "rm -rf lib dist"
  },
  "dependencies": {
    "@wireio/debugging-shared": "workspace:*",
    "@wireio/debugging-client-shared": "workspace:*",
    "@wireio/opp-typescript-models": "^1.0.26",
    "@wireio/shared": "^1.0.21",
    "@wireio/sdk-core": "^1.0.21",
    "lodash": "^4.17.21",
    "ts-pattern": "^5.9.0",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@types/lodash": "^4.17.24",
    "@types/node": "25.5.0",
    "@types/yargs": "^17.0.35",
    "esbuild": "^0.27.3",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.4.6",
    "typescript": "^6.0.2"
  }
}
