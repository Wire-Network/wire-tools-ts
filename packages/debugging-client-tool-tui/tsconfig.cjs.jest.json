{
  "extends": "../../etc/tsconfig/tsconfig.base.jest.json",
  "compilerOptions": {
    "rootDir": "tests",
    "outDir": "lib/test-cjs",
    "module": "commonjs",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "jsx": "react-jsx",
    "paths": {
      "@wireio/debugging-client-tool-tui": ["./src"],
      "@wireio/debugging-client-tool-tui/*": ["./src/*"],
      "@wireio/debugging-shared": ["../debugging-shared/src/index.ts"],
      "@wireio/debugging-shared/*": ["../debugging-shared/src/*"],
      "@wireio/debugging-client-shared": [
        "../debugging-client-shared/src/index.ts"
      ],
      "@wireio/debugging-client-shared/*": [
        "../debugging-client-shared/src/*"
      ]
    }
  },
  "references": [
    { "path": "./tsconfig.cjs.json" }
  ],
  "include": ["tests"]
}
