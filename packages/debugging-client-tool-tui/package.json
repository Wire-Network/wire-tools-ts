{
  "name": "@wireio/debugging-client-tool-tui",
  "version": "0.1.10",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "types": "lib/cjs/tui.d.ts",
  "main": "bin/wire-debugging-client-tui",
  "bin": {
    "wire-debugging-client-tool-tui": "bin/wire-debugging-client-tui",
    "wdc-tui": "bin/wire-debugging-client-tui",
    "wdctui": "bin/wire-debugging-client-tui"
  },
  "files": [
    "dist",
    "lib",
    "bin",
    "src",
    "README.md"
  ],
  "scripts": {
    "compile": "tsc -b tsconfig.json",
    "compile:watch": "tsc -b tsconfig.json -w",
    "build": "pnpm compile && pnpm bundle",
    "bundle": "node esbuild.config.cjs",
    "bundle:watch": "node esbuild.config.cjs --watch",
    "dev": "node esbuild.config.cjs --dev",
    "start": "pnpm run build && node dist/bundle/wire-debugging-client-tool-tui.mjs",
    "dist": "pnpm build",
    "test": "jest",
    "clean": "rm -rf lib dist",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@3fv/prelude-ts": "^0.8.37",
    "@reduxjs/toolkit": "^2.11.2",
    "@wireio/debugging-client-shared": "workspace:*",
    "@wireio/debugging-shared": "workspace:*",
    "@wireio/opp-typescript-models": "^1.0.26",
    "@wireio/sdk-core": "^1.0.21",
    "@wireio/shared": "^1.0.21",
    "bluebird": "^3.7.2",
    "eventemitter3": "^5.0.4",
    "ink": "^7.0.1",
    "lodash": "^4.17.21",
    "react": "^19.2.5",
    "react-redux": "^9.2.0",
    "redux-logger": "^3.0.6",
    "ts-pattern": "^5.9.0",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@types/bluebird": "^3.5.42",
    "@types/lodash": "^4.17.24",
    "@types/node": "25.5.0",
    "@types/react": "^19.2.14",
    "@types/redux-logger": "^3.0.13",
    "@types/yargs": "^17.0.35",
    "esbuild": "^0.28.0",
    "react-devtools": "^7.0.1",
    "react-devtools-core": "^7.0.1",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.2"
  }
}
