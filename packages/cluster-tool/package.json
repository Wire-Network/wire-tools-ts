{
  "name": "@wireio/cluster-tool",
  "version": "0.1.14",
  "private": false,
  "type": "commonjs",
  "types": "lib/cjs/index.d.ts",
  "main": "lib/cjs/index.js",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "lib",
    "bin",
    "src",
    "README.md"
  ],
  "bin": {
    "wire-cluster-tool": "bin/wire-cluster-tool",
    "wtc": "bin/wire-cluster-tool"
  },
  "scripts": {
    "compile": "tsc -b tsconfig.json",
    "compile:watch": "tsc -b tsconfig.json -w",
    "build": "pnpm run compile",
    "dist": "pnpm run build",
    "prepublishOnly": "pnpm run build",
    "prepare": "pnpm run build",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "clean": "rm -rf lib"
  },
  "dependencies": {
    "@3fv/guard": "^1.4.39",
    "@3fv/prelude-ts": "^0.8.41",
    "@coral-xyz/anchor": "^0.31.0",
    "@solana/spl-token": "^0.4.9",
    "@solana/web3.js": "^1.98.0",
    "@wireio/debugging-server": "workspace:*",
    "@wireio/debugging-shared": "workspace:*",
    "@wireio/opp-typescript-models": "^1.0.26",
    "@wireio/sdk-core": "^1.0.21",
    "@wireio/shared": "^1.0.21",
    "@wireio/shared-node": "^1.0.21",
    "bluebird": "^3.7.2",
    "ethers": "^6.14.0",
    "eventemitter3": "^5.0.1",
    "get-port": "^7.2.0",
    "lodash": "^4.17.23",
    "proper-lockfile": "^4.1.2",
    "shelljs": "^0.10.0",
    "source-map-support": "^0.5.21",
    "tree-kill": "^1.2.2",
    "ts-pattern": "^5.9.0",
    "yargs": "^18.0.0",
    "zx": "^8.8.5"
  },
  "devDependencies": {
    "@jest/globals": "^30.0.0",
    "@types/bluebird": "^3.5.42",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.24",
    "@types/node": "25.5.0",
    "@types/proper-lockfile": "^4.1.4",
    "@types/shelljs": "^0.10.0",
    "@types/yargs": "^17.0.35",
    "tweetnacl": "^1.0.3"
  }
}
