{
  "name": "@wireio/debugging-client-shared",
  "version": "0.1.11",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "types": "lib/esm/index.d.ts",
  "main": "lib/cjs/index.js",
  "module": "lib/esm/index.js",
  "exports": {
    ".": {
      "types": "./lib/esm/index.d.ts",
      "import": "./lib/esm/index.js",
      "require": "./lib/cjs/index.js"
    },
    "./*": {
      "types": "./lib/esm/*.d.ts",
      "import": "./lib/esm/*.js",
      "require": "./lib/cjs/*.js"
    }
  },
  "files": [
    "lib",
    "README.md"
  ],
  "scripts": {
    "compile": "tsc -b tsconfig.json",
    "compile:watch": "tsc -b tsconfig.json -w",
    "build": "pnpm run compile && node ../../scripts/fix-hybrid-output.mjs .",
    "test": "jest",
    "clean": "rm -rf lib"
  },
  "dependencies": {
    "@protobuf-ts/runtime": "^2.11.1",
    "@wireio/debugging-shared": "workspace:*",
    "@wireio/opp-typescript-models": "^1.0.26",
    "@wireio/shared": "^1.0.21",
    "@wireio/sdk-core": "^1.0.21",
    "@3fv/prelude-ts": "^0.8.41",
    "bluebird": "^3.7.2",
    "eventemitter3": "^5.0.4",
    "get-port": "^7.2.0",
    "lodash": "^4.17.21",
    "ts-pattern": "^5.9.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/bluebird": "^3.5.42",
    "@types/lodash": "^4.17.24",
    "@types/node": "25.5.0",
    "@types/ws": "^8.5.13",
    "@wireio/debugging-server": "workspace:*",
    "ts-jest": "^29.4.6",
    "typescript": "^6.0.2"
  }
}
